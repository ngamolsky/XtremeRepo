{
  "name": "relay-race-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "gen-types": "npx supabase gen types typescript --local > src/types/database.generated.ts",
    "db:dump-seed:prod": "node scripts/supabase/export-seed.mjs --prod --backup",
    "db:auth:ensure:local": "node scripts/supabase/ensure-runner-auth.mjs --local",
    "db:auth:ensure:prod": "node scripts/supabase/ensure-runner-auth.mjs --prod",
    "db:compare-local-prod": "node scripts/supabase/compare-local-prod.mjs",
    "db:refresh-local": "npm run db:dump-seed:prod && npx supabase db reset && npm run db:auth:ensure:local",
    "photos:import": "node scripts/supabase/import-photos.mjs",
    "results:extract": "node scripts/lake-tahoe-relay/extract-results.mjs",
    "results:load-extracted": "node scripts/supabase/load-result-extractions.mjs",
    "test:result-extraction": "node scripts/test-result-extraction.mjs",
    "test:result-extraction-loader": "node scripts/test-result-extraction-loader.mjs",
    "test:historical-results-search-ui": "node scripts/test-historical-results-search-ui.mjs",
    "test:observation-null": "node scripts/test-observation-null-handling.mjs",
    "test:race-display-provisional": "node scripts/test-race-display-provisional-metrics.mjs",
    "test:race-live-projection": "node scripts/test-race-live-projection.mjs",
    "test:race-live-projection-dark-mode": "node scripts/test-race-live-projection-dark-mode.mjs",
    "test:grade-adjusted-pace": "node scripts/test-grade-adjusted-pace.mjs",
    "test:grade-adjusted-pace-ui": "node scripts/test-grade-adjusted-pace-ui.mjs",
    "test:race-detail-assumed-legend": "node scripts/test-race-detail-assumed-legend.mjs",
    "test:run-instance-leg-link": "node scripts/test-run-instance-leg-link.mjs",
    "test:runner-race-breakdown": "node scripts/test-runner-race-breakdown.mjs",
    "test:runner-race-profile-ui": "node scripts/test-runner-race-profile-ui.mjs",
    "test:falco-branding": "node scripts/test-falco-branding-and-home-link.mjs",
    "test:mobile-nav-breadcrumbs": "node scripts/test-mobile-nav-and-breadcrumbs.mjs",
    "test:xtreme-agent-vibes": "node scripts/test-xtreme-agent-vibes.mjs",
    "test:agent-data-freshness": "node scripts/test-agent-data-freshness.mjs",
    "test:race-detail-leg-links": "node scripts/test-race-detail-leg-links.mjs",
    "test:leg-historical-average-display": "node scripts/test-leg-historical-average-display.mjs",
    "test:information-hierarchy-links": "node scripts/test-information-hierarchy-links-and-leg-results.mjs",
    "results:import-csv": "node scripts/supabase/import-historical-team-results-csv.mjs",
    "test:historical-results-simple-import": "node scripts/test-historical-results-simple-import.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/openai": "^3.0.68",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-router": "^1.170.13",
    "ai": "^6.0.197",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "streamdown": "^2.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.0",
    "@eslint/config-array": "^0.23.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/router-vite-plugin": "^1.167.16",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "supabase": "^2.105.0",
    "tailwindcss": "^4.3.0",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.98.0",
    "xlsx": "^0.18.5"
  }
}
