{
  "name": "relay-race-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "gen-types": "npx supabase gen types typescript --local > src/types/database.generated.ts",
    "db:dump-seed:prod": "node scripts/supabase/export-seed.mjs --prod --backup",
    "db:auth:ensure:local": "node scripts/supabase/ensure-runner-auth.mjs --local",
    "db:auth:ensure:prod": "node scripts/supabase/ensure-runner-auth.mjs --prod",
    "db:compare-local-prod": "node scripts/supabase/compare-local-prod.mjs",
    "db:refresh-local": "npm run db:dump-seed:prod && npx supabase db reset && npm run db:auth:ensure:local"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/openai": "^3.0.68",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-router": "^1.170.13",
    "ai": "^6.0.197",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "streamdown": "^2.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.0",
    "@eslint/config-array": "^0.23.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/router-vite-plugin": "^1.167.16",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "supabase": "^2.105.0",
    "tailwindcss": "^4.3.0",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.98.0"
  }
}
